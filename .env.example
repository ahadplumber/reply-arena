# Copy this to .env and fill in your keys

# X/Twitter API — App-Only Bearer Token (for public tweet lookups)
X_BEARER_TOKEN=

# Anthropic API Key — For pipeline LLM calls (filter, synthesize, score, enrich)
ANTHROPIC_API_KEY=

# Firecrawl API Key (optional) — For deep web extraction, renders JS
FIRECRAWL_API_KEY=
